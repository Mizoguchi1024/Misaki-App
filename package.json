{
  "name": "misaki-app",
  "version": "1.0.0",
  "description": "Misaki APP",
  "main": "./out/main/index.js",
  "author": "https://github.com/Mizoguchi1024",
  "homepage": "https://github.com/Mizoguchi1024/Misaki-App",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win --x64",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@ant-design/icons": "~6.1.1",
    "@ant-design/x": "^2.5.0",
    "@ant-design/x-markdown": "^2.5.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/query-async-storage-persister": "^5.90.27",
    "@tanstack/query-persist-client-core": "^5.92.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.27",
    "antd": "^6.3.1",
    "axios": "^1.15.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "electron-updater": "^6.7.3",
    "howler": "^2.2.4",
    "i18next": "^25.8.13",
    "i18next-http-backend": "^3.0.2",
    "jwt-decode": "^4.0.0",
    "motion": "^12.35.2",
    "pixi.js": "^8.16.0",
    "react-highlight-words": "^0.21.0",
    "react-i18next": "^16.5.4",
    "react-infinite-scroll-component": "^6.1.1",
    "react-router-dom": "^7.13.1",
    "react-use": "^17.6.0",
    "tailwindcss": "^4.2.1",
    "untitled-pixi-live2d-engine": "^1.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.18.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-highlight-words": "^0.20.1",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vite-plugin-svgr": "^4.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
